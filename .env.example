# ─────────────────────────────────────────────
# Firebase — Client (NEXT_PUBLIC — safe to expose)
# Firebase Console > Project Settings > Your Apps > Web app
# ─────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─────────────────────────────────────────────
# Firebase — Admin SDK (SERVER ONLY — never expose)
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Google AI (Gemini)
# aistudio.google.com > Get API Key
# ─────────────────────────────────────────────
GOOGLE_AI_API_KEY=

# ─────────────────────────────────────────────
# Razorpay
# dashboard.razorpay.com > Settings > API Keys
# dashboard.razorpay.com > Subscriptions > Plans (create Monthly + Annual)
# dashboard.razorpay.com > Settings > Webhooks
# ─────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID_MONTHLY=
RAZORPAY_PLAN_ID_ANNUAL=
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Resend (email)
# resend.com > API Keys
# ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@tendersarthi.com

# ─────────────────────────────────────────────
# Algolia (search)
# algolia.com > Settings > API Keys (use Search-Only key for NEXT_PUBLIC)
# ─────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# ─────────────────────────────────────────────
# PostHog (analytics)
# app.posthog.com > Project Settings > API Keys
# ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────
# Upstash Redis (rate limiting)
# console.upstash.com > Create Database > REST API
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────
# MSG91 (WhatsApp alerts)
# msg91.com > API > Auth Key
# ─────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=TSRTHI

# ─────────────────────────────────────────────
# Alert system
# ─────────────────────────────────────────────
ALERT_RSS_URLS=https://eprocure.gov.in/eprocure/app/rssxml
ENABLE_GEM_SCRAPER=false

# ─────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────
ADMIN_EMAIL=
CRON_SECRET=
